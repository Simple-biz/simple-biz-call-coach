# Production Environment Configuration
# Copy this file to .env.production and update with your actual values
# DO NOT commit .env.production to git!

# Backend WebSocket URL (from Elastic Beanstalk)
# Example: wss://devassist-call-coach-prod.us-east-1.elasticbeanstalk.com
VITE_BACKEND_WS_URL=wss://your-backend-url.elasticbeanstalk.com

# Backend API Key (must match API_KEY in backend environment)
# Generate with: openssl rand -base64 32
VITE_BACKEND_API_KEY=your-backend-api-key-here

# Deepgram API Key (for transcription)
# Get from: https://console.deepgram.com/
VITE_DEEPGRAM_API_KEY=your-deepgram-api-key-here

# AWS CDK / Lambda Infrastructure
DATABASE_URL=postgresql://user:password@your-rds-host:5432/your-db-name
ANTHROPIC_API_KEY=sk-ant-your-key-here
BACKEND_API_KEY=your-backend-api-key
OPENAI_API_KEY= your-openai-api-key-here
CALLTOOLS_WEBHOOK_SECRET=your-webhook-secret
ALERT_EMAIL=your-email@example.com

# AWS VPC / Network Configuration
VPC_ID=vpc-xxxxxxxxxxxxxxxxx
PRIVATE_SUBNET_IDS=subnet-xxx,subnet-yyy,subnet-zzz
RDS_SECURITY_GROUP_ID=sg-xxxxxxxxxxxxxxxxx
