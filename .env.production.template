# Production Environment Configuration
# Copy this file to .env.production and update with your actual values
# DO NOT commit .env.production to git!

# Backend WebSocket URL (from Elastic Beanstalk)
# Example: wss://devassist-call-coach-prod.us-east-1.elasticbeanstalk.com
VITE_BACKEND_WS_URL=wss://your-backend-url.elasticbeanstalk.com

# Backend API Key (must match API_KEY in backend environment)
# Generate with: openssl rand -base64 32
VITE_BACKEND_API_KEY=your-backend-api-key-here

# Deepgram API Key (for transcription)
# Get from: https://console.deepgram.com/
VITE_DEEPGRAM_API_KEY=your-deepgram-api-key-here
