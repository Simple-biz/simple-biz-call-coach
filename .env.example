# Simple.Biz Call Coach — Environment Variables
# Copy this file to .env.local for local dev, or .env.production for production builds.
# NEVER commit .env.local or .env.production to git.

# ──────────────────────────────────────────────
# Backend (AWS API Gateway WebSocket)
# ──────────────────────────────────────────────

# WebSocket endpoint (from AWS API Gateway — CDK output after deploy)
# Format: wss://<api-id>.execute-api.us-east-1.amazonaws.com/production
VITE_BACKEND_WS_URL=wss://REPLACE_WITH_API_GATEWAY_URL/production

# Shared API key for WebSocket authentication
# Must match BACKEND_API_KEY set in the Lambda environment (CDK)
# Ask COB for the production value.
VITE_BACKEND_API_KEY=REPLACE_WITH_BACKEND_API_KEY

# ──────────────────────────────────────────────
# Transcription (Deepgram)
# ──────────────────────────────────────────────

# Deepgram API key — used for real-time audio transcription
# Get from: https://console.deepgram.com/
# Note: In production this is entered by each agent at login (not stored here)
VITE_DEEPGRAM_API_KEY=REPLACE_WITH_DEEPGRAM_API_KEY

# ──────────────────────────────────────────────
# Feature Flags
# ──────────────────────────────────────────────

# Enable CallTools webhook-based call detection (Sprint 2 feature)
# Set to true once webhook Lambda is deployed and CallTools is configured
# Defaults to false — uses DOM detection fallback
VITE_WEBHOOK_ENABLED=false
